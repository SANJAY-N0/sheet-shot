{
    "manifest_version": 3,
    "name": "Brave Compatible Google OAuth",
    "version": "1.0",
    "description": "Log in with Google seamlessly across Brave and Chrome.",
    "permissions": [
        "identity",
        "storage"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    }
}